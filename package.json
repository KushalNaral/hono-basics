{
  "name": "hono-basics",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:docker": "docker compose --profile dev up --build -d",
    "prod:docker": "docker compose --profile prod up --build -d",
    "build": "bun build src/index.ts --outdir dist",
    "test": "bun test --preload ./tests/setup.ts",
    "test:docker": "docker compose up db-test -d --wait && bun test --preload ./tests/setup.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "bun run src/scripts/db-check.ts",
    "db:seed": "bun run src/db/seed/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
