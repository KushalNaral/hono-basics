# ================== DATABASE ==================
# Full PostgreSQL connection URL (used by Drizzle / pg / your app)
# Format: postgresql://user:password@host:port/dbname
DB_URL=postgresql://postgres:postgres123@localhost:5433/hono_db?schema=public

# Alternative: Individual DB variables (recommended when using Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=hono_db
POSTGRES_PORT=5433          # Host port (what you access from your machine)

# ================== APPLICATION ==================
# Port on which the Hono app will run
APP_PORT=3000

# Secret key used for encryption, JWT signing, cookies, etc.
# Generate a strong random key (at least 32 characters)
APP_KEY=your-super-secret-app-key-change-this-in-production

# ================== ENVIRONMENT ==================
NODE_ENV=development
# NODE_ENV=production

# ================== OTHER/MISC ==================
BETTER_AUTH_SECRET=Iwie8aJlDYJ7aiTPnFp4nMNR3mzSaJ71
BETTER_AUTH_URL=http://localhost:3000

LOG_LEVEL=info

CORS_ORIGIN=http://localhost:3000
